# ── 抖音直播捕鱼游戏 环境变量配置 ──────────────────────────────────────────────
# 复制本文件为 .env 并填入真实值
# cp .env.example .env

# 服务端口
PORT=3000

# ── 抖音开放平台（接入真实SDK时填写）─────────────────────────────────────────────
# 在 https://developer.open-douyin.com/ 申请
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# ── 管理后台鉴权（可选，留空则不鉴权）────────────────────────────────────────────
ADMIN_PASSWORD=

# ── 数据存储路径（默认 ./data）───────────────────────────────────────────────────
DATA_DIR=./data

# ── CORS 允许的来源（默认允许所有，生产建议设置）────────────────────────────────────
# CORS_ORIGIN=https://your-domain.com
